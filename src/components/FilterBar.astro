---
const filters = [
  { id: 'all', label: 'Tout' },
  { id: 'reading', label: 'En lecture' },
  { id: 'to-read', label: 'À lire' },
  { id: 'finished', label: 'Terminés' },
  { id: 'favorites', label: 'Coups de cœur' },
];
---

<div
  x-data="filterBar()"
  x-init="init()"
  class="sticky top-0 z-40 -mx-4 px-4 md:-mx-6 md:px-6 transition-all duration-500"
  :class="scrolled ? 'backdrop-blur-2xl bg-ink-900/85 border-b border-ink-700/60' : 'bg-transparent'"
>
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col gap-3 py-4 md:flex-row md:items-center md:justify-between">

      <!-- === DESKTOP : chips horizontaux === -->
      <nav class="hidden md:flex items-center gap-1.5" aria-label="Filtres">
        {filters.map(({ id, label }) => (
          <button
            type="button"
            @click={`setFilter('${id}')`}
            :class={`activeFilter === '${id}' ? 'text-ink-900 bg-amber border-amber' : 'text-ink-200 bg-transparent border-ink-600/60 hover:border-amber/60 hover:text-ink-50'`}
            class="group relative shrink-0 rounded-full border px-4 py-1.5 text-xs font-medium uppercase tracking-[0.16em] transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber focus-visible:ring-offset-2 focus-visible:ring-offset-ink-900"
            data-filter={id}
          >
            <span>{label}</span>
            <span
              class="ml-2 text-[10px] tabular-nums opacity-60"
              x-text={`counts['${id}'] ?? ''`}
            ></span>
          </button>
        ))}
      </nav>

      <!-- === MOBILE : dropdown (bouton full-width → liste) === -->
      <div class="md:hidden relative" @click.away="open = false">
        <button
          type="button"
          @click="open = !open"
          :aria-expanded="open"
          aria-controls="filter-dropdown"
          class="group flex w-full items-center justify-between rounded-full border border-ink-600/60 bg-ink-800/70 px-5 py-3 text-left text-sm text-ink-50 transition-colors hover:border-amber/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber/50"
        >
          <span class="flex items-center gap-3">
            <span class="h-2 w-2 rounded-full bg-amber"></span>
            <span class="font-display text-base leading-none" x-text="activeLabel()"></span>
            <span class="rounded-full bg-ink-700/70 px-2 py-0.5 text-[11px] tabular-nums text-ink-200" x-text="counts[activeFilter] ?? 0"></span>
          </span>
          <svg
            class="h-4 w-4 text-ink-300 transition-transform duration-300"
            :class="open ? 'rotate-180 text-amber' : ''"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>

        <div
          id="filter-dropdown"
          x-show="open"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-2"
          class="absolute left-0 right-0 top-full z-50 mt-2 overflow-hidden rounded-2xl border border-ink-600/70 bg-ink-900/95 backdrop-blur-2xl shadow-2xl"
          style="display: none;"
          role="listbox"
        >
          <ul class="py-1">
            {filters.map(({ id, label }) => (
              <li>
                <button
                  type="button"
                  @click={`setFilter('${id}'); open = false`}
                  :class={`activeFilter === '${id}' ? 'bg-amber/15 text-amber' : 'text-ink-100 hover:bg-ink-800/60'`}
                  class="flex w-full items-center justify-between px-5 py-3.5 text-left text-base transition-colors"
                  role="option"
                  :aria-selected={`activeFilter === '${id}'`}
                >
                  <span class="flex items-center gap-3">
                    <span
                      class="h-1.5 w-1.5 rounded-full transition-colors"
                      :class={`activeFilter === '${id}' ? 'bg-amber' : 'bg-ink-500'`}
                    ></span>
                    <span class="font-display leading-none">{label}</span>
                  </span>
                  <span
                    class="text-[11px] tabular-nums"
                    :class={`activeFilter === '${id}' ? 'text-amber/80' : 'text-ink-400'`}
                    x-text={`counts['${id}'] ?? 0`}
                  ></span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- === Search === -->
      <div class="relative flex-shrink-0 w-full md:w-72">
        <div class="relative">
          <svg
            class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            x-ref="searchInput"
            type="search"
            inputmode="search"
            autocomplete="off"
            placeholder="Chercher un titre, un auteur, un genre…"
            class="w-full rounded-full border border-ink-600/60 bg-ink-800/70 py-2.5 pl-10 pr-14 text-sm text-ink-50 placeholder:text-ink-400 outline-none transition-all duration-300 focus:border-amber/60 focus:bg-ink-800 focus:ring-2 focus:ring-amber/20"
            x-model="search"
            @input="apply()"
            @keydown.escape="clearSearch()"
          />
          <kbd
            x-show="!search"
            class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 hidden md:inline-flex rounded border border-ink-600/50 bg-ink-800 px-1.5 py-0.5 text-[10px] font-medium text-ink-400"
          >
            ⌘K
          </kbd>
          <button
            type="button"
            x-show="search"
            @click="clearSearch()"
            class="absolute right-2 top-1/2 -translate-y-1/2 rounded-full p-1 text-ink-400 hover:text-amber transition-colors"
            aria-label="Effacer la recherche"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Empty state that lives at the end of the page -->
<div
  id="filter-empty-state"
  class="hidden col-span-full text-center py-20"
>
  <p class="font-display italic text-3xl text-amber/80 mb-2">Aucun livre ne correspond</p>
  <p class="text-sm text-ink-300">Essayez un autre filtre ou une autre recherche.</p>
</div>

<script is:inline define:vars={{ filters }}>
  function filterBar() {
    return {
      activeFilter: 'all',
      search: '',
      scrolled: false,
      counts: {},
      open: false,
      _filters: filters,

      init() {
        this.computeCounts();
        this.apply();
        window.addEventListener('scroll', () => {
          this.scrolled = window.scrollY > 16;
        }, { passive: true });
        window.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
            e.preventDefault();
            this.$refs.searchInput?.focus();
          }
        });
      },

      computeCounts() {
        const books = document.querySelectorAll('[data-book-status]');
        const counts = { all: 0, reading: 0, 'to-read': 0, finished: 0, favorites: 0 };
        books.forEach((b) => {
          counts.all++;
          const st = b.getAttribute('data-book-status');
          if (st && counts[st] !== undefined) counts[st]++;
          if (b.getAttribute('data-favorite') === 'true') counts.favorites++;
        });
        this.counts = counts;
      },

      activeLabel() {
        const f = this._filters.find(x => x.id === this.activeFilter);
        return f ? f.label : 'Tout';
      },

      setFilter(id) {
        this.activeFilter = id;
        this.apply();
      },

      clearSearch() {
        this.search = '';
        this.$refs.searchInput?.blur();
        this.apply();
      },

      normalize(s) {
        return (s || '')
          .toString()
          .toLowerCase()
          .normalize('NFD')
          .replace(/[̀-ͯ]/g, ''); // remove accents
      },

      apply() {
        const books = document.querySelectorAll('[data-book-status]');
        const q = this.normalize(this.search).trim();
        let visible = 0;

        books.forEach((book) => {
          const status = book.getAttribute('data-book-status');
          const haystack = this.normalize(
            (book.getAttribute('data-book-title') || '') + ' ' +
            (book.getAttribute('data-book-authors') || '') + ' ' +
            (book.getAttribute('data-book-genres') || '')
          );
          const isFav = book.getAttribute('data-favorite') === 'true';

          let matchFilter = false;
          if (this.activeFilter === 'all') matchFilter = true;
          else if (this.activeFilter === 'favorites') matchFilter = isFav;
          else matchFilter = status === this.activeFilter;

          const matchSearch = !q || haystack.includes(q);
          const show = matchFilter && matchSearch;

          book.classList.toggle('hidden', !show);
          if (show) visible++;
        });

        const empty = document.getElementById('filter-empty-state');
        if (empty) empty.classList.toggle('hidden', visible > 0);
      },
    };
  }
  window.filterBar = filterBar;
</script>
