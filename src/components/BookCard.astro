---
import { slugify } from '../utils/slugify';
import type { Book } from '../types/book';

interface Props {
  book: Book;
  compact?: boolean;
  priority?: boolean;
  index?: number;
}

const { book, compact = false, priority = false, index = 0 } = Astro.props;

const slug = book.title ? slugify(book.title) : book.id;
const href = `/book/${slug}`;

const statusMeta: Record<string, { label: string; toneClass: string; dotClass: string }> = {
  reading: {
    label: 'En lecture',
    toneClass: 'text-inkblue bg-inkblue/10 border-inkblue/30',
    dotClass: 'bg-inkblue',
  },
  finished: {
    label: 'Terminé',
    toneClass: 'text-amber bg-amber/10 border-amber/30',
    dotClass: 'bg-amber',
  },
  'to-read': {
    label: 'À lire',
    toneClass: 'text-ink-200 bg-ink-700/60 border-ink-500/40',
    dotClass: 'bg-ink-300',
  },
};

const status = statusMeta[book.status] ?? statusMeta['to-read'];
const rating = typeof book.rating === 'number' ? Math.max(0, Math.min(5, book.rating)) : null;
const hasCover = Boolean(book.imageUrl);
---

<article
  class="reveal group relative h-full"
  style={`transition-delay:${Math.min(index * 35, 600)}ms`}
  data-book-status={book.status}
  data-book-title={book.title}
  data-favorite={book.favorite ? 'true' : 'false'}
>
  <a
    href={href}
    data-astro-prefetch="hover"
    class="relative flex h-full flex-col focus:outline-none focus-visible:ring-2 focus-visible:ring-amber focus-visible:ring-offset-2 focus-visible:ring-offset-ink-900 rounded-sm"
  >
    <!-- Cover -->
    <div
      transition:name={`cover-${book.id}`}
      class="relative w-full overflow-hidden bg-ink-800 shadow-book transition-all duration-500 ease-out group-hover:shadow-book-hover group-hover:-translate-y-1"
      style="aspect-ratio: 2 / 3"
    >
      {hasCover ? (
        <>
          <div class="skeleton-shimmer absolute inset-0" aria-hidden="true"></div>
          <img
            src={book.imageUrl}
            alt={`Couverture de ${book.title}`}
            width="400"
            height="600"
            loading={priority ? 'eager' : 'lazy'}
            decoding="async"
            fetchpriority={priority ? 'high' : 'auto'}
            onload="this.previousElementSibling && this.previousElementSibling.remove(); this.style.opacity='1';"
            onerror="this.style.opacity='0'"
            style="opacity:0;transition:opacity 0.6s ease"
            class="relative z-10 h-full w-full object-cover transition-transform duration-700 ease-out will-change-transform group-hover:scale-[1.04]"
          />
        </>
      ) : (
        <div class="flex h-full w-full flex-col items-center justify-center gap-3 p-6 text-center">
          <span class="font-display italic text-2xl leading-none text-amber/70">{book.title.slice(0, 1)}</span>
          <span class="text-[10px] uppercase tracking-[0.2em] text-ink-400">Sans couverture</span>
        </div>
      )}

      <!-- Gradient overlay on hover -->
      <div
        class="absolute inset-0 z-20 bg-gradient-to-t from-ink-900/90 via-ink-900/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        aria-hidden="true"
      ></div>

      <!-- Status badge -->
      <div class="absolute left-3 top-3 z-30 flex flex-wrap gap-1.5">
        <span class={`inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.12em] backdrop-blur-md ${status.toneClass}`}>
          <span class={`h-1.5 w-1.5 rounded-full ${status.dotClass}`}></span>
          {status.label}
        </span>
        {book.abandoned && (
          <span class="inline-flex items-center rounded-full border border-terracotta/40 bg-terracotta/10 px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.12em] text-terracotta backdrop-blur-md">
            Abandonné
          </span>
        )}
      </div>

      <!-- Favorite heart (top right) -->
      {book.favorite && (
        <div class="absolute right-3 top-3 z-30">
          <span class="flex h-8 w-8 items-center justify-center rounded-full border border-amber/40 bg-ink-900/60 backdrop-blur-md" title="Coup de cœur">
            <svg class="h-4 w-4 text-amber" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 21s-7-4.35-9.5-8.5C.5 8.5 3 5 6.5 5c2 0 3.5 1 5.5 3.5C14 6 15.5 5 17.5 5c3.5 0 6 3.5 4 7.5C19 16.65 12 21 12 21z"/>
            </svg>
          </span>
        </div>
      )}

      <!-- Caption on hover -->
      <div class="absolute inset-x-0 bottom-0 z-30 p-4 opacity-0 transition-all duration-500 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0">
        {book.genres && book.genres.length > 0 && (
          <div class="flex flex-wrap items-center gap-x-1.5 gap-y-0.5">
            {book.genres.slice(0, 3).map((g, i) => (
              <>
                {i > 0 && <span class="text-amber/40" aria-hidden="true">·</span>}
                <span class="text-[10px] uppercase tracking-[0.15em] text-amber/90">{g}</span>
              </>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Text block -->
    <div class="pt-4 pb-2 flex flex-col gap-1.5">
      <h3 class="font-display text-[17px] leading-snug tracking-display text-ink-50 line-clamp-2 group-hover:text-amber transition-colors duration-300">
        {book.title}
      </h3>

      {book.authors && book.authors.length > 0 && (
        <p class="text-[11px] uppercase tracking-[0.18em] text-ink-300 line-clamp-1">
          {book.authors.join(' · ')}
        </p>
      )}

      <div class="flex items-center justify-between pt-1 text-ink-400">
        {rating !== null && rating > 0 ? (
          <div class="flex items-center gap-0.5" aria-label={`Note : ${rating} sur 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class={`h-3 w-3 ${i < rating ? 'text-amber' : 'text-ink-600'}`}
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 17.3 5.82 21l1.64-7.03L2 9.24l7.19-.62L12 2l2.81 6.62 7.19 .62-5.46 4.73L18.18 21z"/>
              </svg>
            ))}
          </div>
        ) : (
          <span class="text-[10px] uppercase tracking-[0.18em] text-ink-500">Non noté</span>
        )}

        {book.status === 'reading' && typeof book.progress === 'number' && (
          <span class="text-[10px] uppercase tracking-[0.18em] text-inkblue">{book.progress}%</span>
        )}

        {book.endDate && book.status === 'finished' && (
          <time datetime={book.endDate} class="text-[10px] uppercase tracking-[0.18em] text-ink-500">
            {new Date(book.endDate).toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' })}
          </time>
        )}
      </div>
    </div>
  </a>
</article>
