---
import booksData from '@data/books.json';
import type { Book } from '../../types/book';
import { slugify } from '../../utils/slugify';

export async function getStaticPaths() {
  const books = booksData.books as Book[];
  return books.map((book) => ({
    params: { id: book.id },
    props: { book },
  }));
}

const { book } = Astro.props as { book: Book };
const slug = book.title ? slugify(book.title) : book.id;
const canonical = `https://lectures.yoandev.co/book/${slug}/`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonical} />
    <meta http-equiv="refresh" content={`0; url=/book/${slug}/`} />
    <title>Redirection…</title>
  </head>
  <body>
    <p>Cette page a été déplacée — <a href={`/book/${slug}/`}>ouvrir la nouvelle page</a>.</p>
    <script is:inline set:html={`window.location.replace('/book/${slug}/');`}></script>
  </body>
</html>
